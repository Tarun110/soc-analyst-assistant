# OpenAI API key (required for LLM and embeddings)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG settings
CHROMA_PERSIST_DIR=./data/chroma_db
RETRIEVAL_TOP_K=5

# API settings
API_HOST=0.0.0.0
API_PORT=8000
